{
  "compilerOptions": {
    "outDir": "./dist", // Directory to output compiled files
    "rootDir": "./src", // Root directory of input files
    "target": "ES6",
    "module": "ESNext",
    "jsx": "react",
    "strict": true,
    "moduleResolution": "bundler",
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "allowSyntheticDefaultImports": true,
    "declaration": true, // Generate .d.ts files
    "declarationDir": "./dist", // Directory to output .d.ts files
    "types": ["youtube", "vitest/globals"]
  },
  "include": ["src", ".storybook", "src/react-docgen-types.d.ts"]
}
